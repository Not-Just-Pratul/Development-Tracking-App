[DATABASE]
# PostgreSQL connection settings - Update these for your environment
# Option 1: Use individual connection parameters (local PostgreSQL)
HOST = localhost
PORT = 5432
DBNAME = development_tracking
USER = postgres
PASSWORD = your_password_here

# Option 2: Use full DATABASE_URL (for cloud providers like Neon, Railway, Supabase)
# DATABASE_URL = postgresql://user:password@host:port/dbname?sslmode=require

# Connection pool settings
MIN_CONNECTIONS = 5
MAX_CONNECTIONS = 20
CONNECTION_TIMEOUT = 30

[FLASK]
# Flask application settings
# IMPORTANT: Change SECRET_KEY to a random string in production
SECRET_KEY = change_this_to_a_random_string_in_production
DEBUG = False
HOST = 0.0.0.0
PORT = 5003

[SECURITY]
SESSION_TIMEOUT_MINUTES = 0
MAX_LOGIN_ATTEMPTS = 0
ENABLE_AUDIT_LOGS = True

[EMAIL]
# SMTP configuration for email notifications
# Leave disabled to skip sending emails
ENABLED = False
SMTP_SERVER = smtp.gmail.com
SMTP_PORT = 587
SMTP_USERNAME = your_email@gmail.com
SMTP_PASSWORD = your_app_password
FROM_NAME = Development Tracking System
FROM_EMAIL = your_email@gmail.com
USE_TLS = True

[SCHEMA]
VERSION = 1
